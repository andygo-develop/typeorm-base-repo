{
  "name": "@andygo.dev/typeorm-base-repo",
  "version": "0.1.2",
  "description": "Enhanced TypeORM repository base class with scoping, response caching, keyset pagination, and many-to-many helpers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint \"{src,tests}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{src,tests}/**/*.ts\" --max-warnings=0 --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepublishOnly": "npm run clean && npm run build",
    "preversion": "npm run lint && npm test && npm run build",
    "postversion": "git push --follow-tags && npm publish --access public",
    "deploy": "npm version patch",
    "deploy:minor": "npm version minor",
    "deploy:major": "npm version major"
  },
  "keywords": [
    "typeorm",
    "repository",
    "nestjs",
    "postgres",
    "cache",
    "keyset-pagination"
  ],
  "author": "Andy Kramar <andygo.develop@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.3",
    "@types/jest": "29.5.14",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jest": "29.7.0",
    "reflect-metadata": "^0.2.0",
    "sql.js": "^1.10.3",
    "ts-jest": "29.2.5",
    "typeorm": "^0.3.30",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/tests/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json",
          "diagnostics": true
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts"
    ]
  },
  "dependencies": {
    "@nestjs/typeorm": "^11.0.1"
  }
}
